# ── Provider selection ─────────────────────────────────────────────────────
# Options: gemini_adc | nvidia_nim | deepseek_nim
LLM_PROVIDER=gemini_adc

# ── Google Gemini ──────────────────────────────────────────────────────────
# Option A: API key (simplest)
# GOOGLE_API_KEY=your-api-key-here

# Option B: Vertex AI via Application Default Credentials
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# Model: gemini-2.5-pro | gemini-2.5-flash | gemini-2.5-flash-lite
GEMINI_MODEL=gemini-2.5-flash

# ── NVIDIA NIM (DeepSeek / Nemotron) ──────────────────────────────────────
# Get free key: https://build.nvidia.com → sign up → API Keys
# NVIDIA_API_KEY=nvapi-your-key-here
# NVIDIA_MODEL=deepseek-ai/deepseek-v4-pro

# ── Virtuoso Bridge Connection ────────────────────────────────────────────
# These are read by virtuoso-bridge-lite (VirtuosoClient.from_env())
# VB_REMOTE_HOST=10.2.40.35
# VB_REMOTE_USER=your_username
# VB_REMOTE_PORT=65081
# VB_LOCAL_PORT=65082
